{
  "name": "todolist-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "doctor": "node scripts/doctor.mjs",
    "predeploy": "npm run doctor && npm test && npm run check && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.59.0",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.4",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "cookie": "^0.7.2",
    "esbuild": "^0.25.0"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.9",
    "@better-auth/passkey": "^1.6.9",
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2"
  }
}
